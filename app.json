{
  "expo": {
    "name": "Finapp",
    "slug": "finapp",
    "scheme": "finapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand-welcome.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand-welcome.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand-welcome.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gabrielsbranco.finapp"
    },
    "web": {
      "favicon": "./assets/brand-welcome.png"
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "cde681f5-fbcf-497a-9589-25216661b980"
      }
    }
  }
}
